<?xml version="1.0"?>
<!--
    IMPORTANT: Run tests with `composer test-unit`, not `vendor/bin/phpunit` directly.

    The shipped init.php enforces `defined('ABSPATH') || exit` and is registered in
    Composer's autoload.files, so it executes the moment vendor/autoload.php is required,
    which is before phpunit reads this config file. Running phpunit directly will silently
    exit with code 0 and produce no output because ABSPATH is not defined in time.

    The `composer test-unit` script passes `-d auto_prepend_file=tests/define-abspath.php`
    to PHP, which prepends that file before anything else runs, defining ABSPATH so
    init.php's guard passes. That is the only supported way to run the test suite.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         failOnWarning="true">
    <testsuites>
        <testsuite name="Unit">
            <directory suffix="Test.php">tests/Unit</directory>
        </testsuite>
    </testsuites>
</phpunit>
