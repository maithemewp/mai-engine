#!/bin/sh
#
# Pre-commit: block a with-dev composer autoloader from being committed.
#
# vendor/composer/autoload_files.php eagerly require()s its entries at load time.
# If it was regenerated with dev dependencies installed, it points at dev-only
# packages that .gitignore excludes from the commit, so a raw-branch deploy (no
# composer step) fatals on load. This runs the same check CI does, but locally
# before the commit lands. It only fires when vendor/composer/ is staged, so
# normal commits pay nothing.
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# Fix when it blocks you:
#   composer dump-autoload --no-dev
#
if git diff --cached --name-only | grep -q '^vendor/composer/'; then
	php bin/verify-deployable.php || exit 1
fi
